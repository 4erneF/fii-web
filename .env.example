# Скопируйте в `.env` и заполните значениями. Никогда не коммитьте `.env`.

# Сгенерируйте: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Локально оставьте пустым — будет SQLite в backend/data/fii.db.
# На Railway переменная DATABASE_URL пробросится автоматически из Postgres-плагина.
DATABASE_URL=

# Логин/пароль первого администратора (создаётся при первом запуске, если в БД нет users).
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# CORS — какие фронтенд-хосты могут стучаться в API.
# Через запятую. В проде укажите реальные домены.
FRONTEND_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
ADMIN_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# Сколько часов живёт JWT.
JWT_TTL_HOURS=12

# Лимит загружаемых файлов.
MAX_UPLOAD_BYTES=8388608
